# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override for AI Coach streaming
ANTHROPIC_COACH_MODEL=claude-sonnet-4-5

# Google Cloud Vision (OCR for handwriting / scanned worksheets)
GOOGLE_CLOUD_API_KEY=your_google_cloud_key
GOOGLE_CLOUD_PROJECT_ID=your_project_id

# MoMo Payment (server-side only — do NOT prefix with NEXT_PUBLIC_)
MOMO_PARTNER_CODE=your_partner_code
MOMO_ACCESS_KEY=your_access_key
MOMO_SECRET_KEY=your_secret_key
MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:3000/payment/success?provider=momo
MOMO_NOTIFY_URL=http://localhost:3000/api/payment/webhook?provider=momo

# VNPAY (server-side only)
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payment/success?provider=vnpay

# Rate limiting (Upstash Redis — free tier is enough for dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email (Resend) — used by weekly summary + transactional emails
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@pid.vn

# Zalo OA (optional — weekly alert pings)
ZALO_OA_ACCESS_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PID
